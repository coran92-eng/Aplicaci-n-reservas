# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Connection pooler (recommended for serverless — Transaction Mode, port 6543)
# Found in: Supabase Dashboard → Settings → Database → Connection pooling
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[pw]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── Resend (email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=reservas@cortedemanga.es
# Webhook secret from Resend Dashboard → Webhooks (optional, for bounce/complaint tracking)
# RESEND_WEBHOOK_SECRET=whsec_xxxxx

# ── Admin ────────────────────────────────────────────────────
# Email used for admin notifications and magic link login
ADMIN_EMAIL=coran@cortedemanga.es
# Password for the admin panel (min 12 characters)
ADMIN_PASSWORD=cambia-esta-contraseña-segura
# Secret for signing admin session cookies and magic links (min 32 random chars)
ADMIN_MAGIC_LINK_SECRET=change-me-to-a-long-random-secret

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://reservas-cortedemanga.vercel.app
RESTAURANT_NAME="Corte de Manga"
RESTAURANT_PHONE="+34 623 216 562"
RESTAURANT_ADDRESS="Comte d'Urgell 108, 08011 Barcelona"
RESTAURANT_GOOGLE_MAPS_URL=https://maps.google.com/?q=Corte+de+Manga+Barcelona
# RESTAURANT_LOGO_URL=https://your-cdn.com/logo.png

# ── Cron jobs ────────────────────────────────────────────────
# Random secret used to authenticate Vercel cron endpoints
CRON_SECRET=cambia-a-un-secreto-aleatorio

# ── Sentry (optional) ────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_xxxxx

# ── Playwright E2E ────────────────────────────────────────────
# PLAYWRIGHT_BASE_URL=http://localhost:3000
